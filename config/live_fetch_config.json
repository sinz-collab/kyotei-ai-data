{
  "timezone": "Asia/Tokyo",
  "fetch_start": "08:20",
  "fetch_end": "23:00",
  "interval_minutes": 4,
  "end_time_exclusive": true,
  "active_venues_only": true,
  "skip_when_no_target_races": true,
  "race_monitor_minutes_before_deadline": 45,
  "max_retries": 3,
  "connect_timeout_seconds": 15,
  "read_timeout_seconds": 30,
  "max_parallel_venues": 3,
  "atomic_write": true,
  "preserve_last_complete_data_on_error": true,
  "update_only_when_changed": true,
  "openai_enabled": false,
  "llm_enabled": false,
  "source_base_url": "https://boaters-boatrace.com",
  "source_user_agent": "SINZ-EDGE-LiveFetcher/1.0 (+https://sinz-collab.github.io/kyotei-ai-site/)",
  "domain_interval_seconds": 1.5,
  "navigation_timeout_seconds": 45,
  "race_timeout_seconds": 150,
  "process_timeout_seconds": 210,
  "publish_mode": "vps",
  "publish_interval_minutes": 12,
  "morning_data_base_url": "https://raw.githubusercontent.com/sinz-collab/kyotei-ai-data/main/data",
  "morning_data_root": "runtime/morning",
  "live_output_root": "data/live",
  "log_path": "logs/live_fetch.jsonl",
  "lock_path": "run/live_fetch.lock",
  "publish_lock_path": "run/live_publish.lock",
  "publish_repo_root": "runtime/publisher-repo"
}
